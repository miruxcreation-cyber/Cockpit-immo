// ══ SWIPE ══
let tx=0,ty=0;
const track=document.querySelector('.slider-track');
track.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
track.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx;
  const dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)<Math.abs(dy)*1.3||Math.abs(dx)<44)return;
  const s=SCREENS[cur];
  const isAuto=AUTO_SCREENS.includes(s);
  if(dx<-44&&cur<SCREENS.length-1&&!isAuto)goTo(cur+1);
  if(dx>44&&cur>1)goTo(cur-1);
},{passive:true});

// ══ INIT ══
document.querySelectorAll('.slide').forEach(s=>s.style.display='none');
